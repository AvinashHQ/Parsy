{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avinashhq.local/schemas/canonical-invoice-v2.json",
  "title": "Canonical Invoice v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_id",
    "document_type",
    "source",
    "locale",
    "supplier",
    "invoice",
    "totals",
    "tax_breakdowns",
    "line_items",
    "evidence",
    "uncertainties"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "document_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "document_type": {
      "enum": [
        "invoice",
        "tax_invoice",
        "commercial_invoice",
        "receipt",
        "credit_note",
        "debit_note",
        "proforma_invoice",
        "self_billed_invoice",
        "unknown"
      ]
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "locale": {
      "$ref": "#/$defs/locale"
    },
    "supplier": {
      "$ref": "#/$defs/party"
    },
    "buyer": {
      "anyOf": [
        {
          "$ref": "#/$defs/party"
        },
        {
          "type": "null"
        }
      ]
    },
    "payee": {
      "anyOf": [
        {
          "$ref": "#/$defs/party"
        },
        {
          "type": "null"
        }
      ]
    },
    "invoice": {
      "$ref": "#/$defs/invoice"
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "maxItems": 100
    },
    "allowances_charges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/allowanceCharge"
      },
      "maxItems": 200
    },
    "totals": {
      "$ref": "#/$defs/totals"
    },
    "tax_breakdowns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/taxBreakdown"
      },
      "maxItems": 200
    },
    "line_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lineItem"
      },
      "maxItems": 2000
    },
    "payment": {
      "anyOf": [
        {
          "$ref": "#/$defs/payment"
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      },
      "maxItems": 5000
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/uncertainty"
      },
      "maxItems": 500
    }
  },
  "$defs": {
    "decimal": {
      "type": "string",
      "pattern": "^-?\\d+(\\.\\d{1,8})?$"
    },
    "nullableDecimal": {
      "anyOf": [
        {
          "$ref": "#/$defs/decimal"
        },
        {
          "type": "null"
        }
      ]
    },
    "countryCode": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "languageTag": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[A-Za-z]{2,8}(-[A-Za-z0-9]{1,8})*$"
        },
        {
          "type": "null"
        }
      ]
    },
    "date": {
      "anyOf": [
        {
          "type": "string",
          "format": "date"
        },
        {
          "type": "null"
        }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "route",
        "mime_type",
        "profile",
        "profile_version",
        "page_count",
        "has_embedded_structured_data"
      ],
      "properties": {
        "family": {
          "enum": [
            "visual_pdf",
            "image",
            "hybrid_pdf_xml",
            "ubl",
            "cii",
            "peppol_bis",
            "xrechnung",
            "fatturapa",
            "india_einvoice",
            "brazil_nfe",
            "unknown_structured",
            "unknown_visual"
          ]
        },
        "route": {
          "enum": [
            "visual_model",
            "structured_parser",
            "hybrid_compare",
            "quarantine"
          ]
        },
        "mime_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "profile_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "page_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "has_embedded_structured_data": {
          "type": "boolean"
        }
      }
    },
    "locale": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_language",
        "script",
        "supplier_country",
        "buyer_country",
        "jurisdiction_candidates",
        "applied_region_pack"
      ],
      "properties": {
        "document_language": {
          "$ref": "#/$defs/languageTag"
        },
        "script": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Z][a-z]{3}$"
        },
        "supplier_country": {
          "$ref": "#/$defs/countryCode"
        },
        "buyer_country": {
          "$ref": "#/$defs/countryCode"
        },
        "jurisdiction_candidates": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]{2}(-[A-Z0-9-]+)?$"
          },
          "uniqueItems": true
        },
        "applied_region_pack": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "version",
            "resolution"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "resolution": {
              "enum": [
                "tenant_config",
                "operator_hint",
                "structured_metadata",
                "detected_consensus",
                "generic_fallback"
              ]
            }
          }
        }
      }
    },
    "identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheme",
        "value",
        "issuing_country",
        "purpose"
      ],
      "properties": {
        "scheme": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "issuing_country": {
          "$ref": "#/$defs/countryCode"
        },
        "purpose": {
          "enum": [
            "tax",
            "business",
            "electronic_address",
            "government",
            "other"
          ]
        }
      }
    },
    "address": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lines",
        "city",
        "subdivision",
        "postal_code",
        "country_code"
      ],
      "properties": {
        "lines": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 300
          },
          "maxItems": 5
        },
        "city": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "subdivision": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "postal_code": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        },
        "country_code": {
          "$ref": "#/$defs/countryCode"
        }
      }
    },
    "party": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "legal_name",
        "trading_name",
        "identifiers",
        "address",
        "electronic_addresses"
      ],
      "properties": {
        "display_name": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "legal_name": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "trading_name": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "identifiers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "maxItems": 30
        },
        "address": {
          "anyOf": [
            {
              "$ref": "#/$defs/address"
            },
            {
              "type": "null"
            }
          ]
        },
        "electronic_addresses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "maxItems": 10
        }
      }
    },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_date",
        "end_date"
      ],
      "properties": {
        "start_date": {
          "$ref": "#/$defs/date"
        },
        "end_date": {
          "$ref": "#/$defs/date"
        }
      }
    },
    "invoice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "issue_date",
        "due_date",
        "tax_point_date",
        "currency",
        "tax_currency",
        "service_period",
        "payment_terms_text"
      ],
      "properties": {
        "number": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 256
        },
        "issue_date": {
          "$ref": "#/$defs/date"
        },
        "due_date": {
          "$ref": "#/$defs/date"
        },
        "tax_point_date": {
          "$ref": "#/$defs/date"
        },
        "currency": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "tax_currency": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "service_period": {
          "anyOf": [
            {
              "$ref": "#/$defs/period"
            },
            {
              "type": "null"
            }
          ]
        },
        "payment_terms_text": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1000
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value",
        "scheme",
        "issue_date"
      ],
      "properties": {
        "type": {
          "enum": [
            "purchase_order",
            "contract",
            "delivery_note",
            "original_invoice",
            "project",
            "buyer_accounting",
            "government",
            "tax_platform",
            "other"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "scheme": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        },
        "issue_date": {
          "$ref": "#/$defs/date"
        }
      }
    },
    "allowanceCharge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "charge_indicator",
        "amount",
        "base_amount",
        "percentage",
        "reason_code",
        "reason"
      ],
      "properties": {
        "charge_indicator": {
          "type": "boolean"
        },
        "amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "base_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "percentage": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "reason_code": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        },
        "reason": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        }
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line_extension_amount",
        "allowance_total_amount",
        "charge_total_amount",
        "tax_exclusive_amount",
        "total_tax_amount",
        "tax_inclusive_amount",
        "prepaid_amount",
        "withholding_total_amount",
        "rounding_amount",
        "payable_amount"
      ],
      "properties": {
        "line_extension_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "allowance_total_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "charge_total_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "tax_exclusive_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "total_tax_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "tax_inclusive_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "prepaid_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "withholding_total_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "rounding_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "payable_amount": {
          "$ref": "#/$defs/nullableDecimal"
        }
      }
    },
    "taxBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tax_type",
        "component",
        "jurisdiction_code",
        "category_code",
        "rate",
        "taxable_amount",
        "tax_amount",
        "payable_effect",
        "exemption_code",
        "exemption_reason",
        "reverse_charge",
        "source_label"
      ],
      "properties": {
        "tax_type": {
          "enum": [
            "VAT",
            "GST",
            "SALES_TAX",
            "WITHHOLDING",
            "DUTY",
            "EXCISE",
            "CESS",
            "OTHER"
          ]
        },
        "component": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        },
        "jurisdiction_code": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        },
        "category_code": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        },
        "rate": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "taxable_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "tax_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "payable_effect": {
          "enum": [
            "add",
            "subtract",
            "none"
          ]
        },
        "exemption_code": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        },
        "exemption_reason": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "reverse_charge": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "source_label": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheme",
        "value"
      ],
      "properties": {
        "scheme": {
          "type": "string",
          "maxLength": 64
        },
        "value": {
          "type": "string",
          "maxLength": 256
        }
      }
    },
    "lineItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line_id",
        "line_no",
        "description",
        "item_name",
        "seller_item_id",
        "buyer_item_id",
        "classifications",
        "quantity",
        "unit_code",
        "unit_price",
        "price_base_quantity",
        "allowances_charges",
        "line_net_amount",
        "tax_breakdowns",
        "line_gross_amount",
        "service_period"
      ],
      "properties": {
        "line_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "line_no": {
          "type": "integer",
          "minimum": 1
        },
        "description": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        },
        "item_name": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "seller_item_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 256
        },
        "buyer_item_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 256
        },
        "classifications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/classification"
          },
          "maxItems": 20
        },
        "quantity": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "unit_code": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 32
        },
        "unit_price": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "price_base_quantity": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "allowances_charges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/allowanceCharge"
          },
          "maxItems": 50
        },
        "line_net_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "tax_breakdowns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/taxBreakdown"
          },
          "maxItems": 30
        },
        "line_gross_amount": {
          "$ref": "#/$defs/nullableDecimal"
        },
        "service_period": {
          "anyOf": [
            {
              "$ref": "#/$defs/period"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "paymentMean": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type_code",
        "type_label",
        "payment_reference",
        "account_last4",
        "iban_last4",
        "bic"
      ],
      "properties": {
        "type_code": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        },
        "type_label": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "payment_reference": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 256
        },
        "account_last4": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9]{4}$"
        },
        "iban_last4": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9]{4}$"
        },
        "bic": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 16
        }
      }
    },
    "payment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "means",
        "terms_text"
      ],
      "properties": {
        "means": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/paymentMean"
          },
          "maxItems": 10
        },
        "terms_text": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1000
        }
      }
    },
    "bbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x1",
        "y1",
        "x2",
        "y2"
      ],
      "properties": {
        "x1": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y1": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "x2": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y2": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_path",
        "source_kind",
        "page",
        "source_path",
        "text",
        "bbox"
      ],
      "properties": {
        "field_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "source_kind": {
          "enum": [
            "visual",
            "embedded_structured",
            "standalone_structured"
          ]
        },
        "page": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "source_path": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1000
        },
        "text": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 300
        },
        "bbox": {
          "anyOf": [
            {
              "$ref": "#/$defs/bbox"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "field_paths",
        "message",
        "candidate_values"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "field_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 20
        },
        "message": {
          "type": "string",
          "maxLength": 500
        },
        "candidate_values": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          },
          "maxItems": 20
        }
      }
    }
  }
}
