# Parsy — local environment template.
#
# Copy this to `.env` and fill in real values:   cp .env.example .env
# `.env` is gitignored (see .gitignore); NEVER commit real secrets.
#
# Loading:
#   • `bin/dev` runs foreman, which loads `.env` automatically — no gem needed.
#   • `bin/rails console` / `runner` / `bin/rails test` do NOT load `.env` on their own.
#     Either add the `dotenv-rails` gem (loads `.env` everywhere) or `export` the vars
#     in your shell for those commands.
#
# This project reads all config from ENV (there are no Rails encrypted credentials).

# ── Extraction provider (M4.5) ────────────────────────────────────────────────
# Which semantic extraction backend runs: "gemini" (cloud, MVP default) or
# "ollama" (local fallback). See ADR-026.
PARSY_EXTRACTION_PROVIDER=gemini

# Google Gemini API key — REQUIRED when PARSY_EXTRACTION_PROVIDER=gemini.
# Create a free key at https://aistudio.google.com/apikey . Keep it secret.
GEMINI_API_KEY=

# Optional: override the Gemini model the client requests (code sets a sane default).
# GEMINI_MODEL=gemini-2.5-flash

# ── Local model fallback (Ollama) ─────────────────────────────────────────────
# Only used when PARSY_EXTRACTION_PROVIDER=ollama.
PARSY_OLLAMA_URL=http://localhost:11434
PARSY_OLLAMA_MODEL=qwen3-vl:4b
PARSY_OLLAMA_OCR_MODEL=glm-ocr

# ── Private object storage (S3) — optional in local dev ───────────────────────
# Needed only when exercising production-like private Active Storage instead of
# local disk. In production these come from .kamal/secrets, not this file.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-2
# PRIVATE_STORAGE_BUCKET=

# ── Active Record encryption (M4.5 destination credentials) ──────────────────
# Encrypts destination database credentials at rest (ADR-027). Generate three
# random values once (e.g. `openssl rand -hex 32` per key) and keep them stable —
# rotating them orphans previously encrypted values. Required in development and
# production before saving a destination connection. The test environment uses
# fixed non-secret keys from config/initializers/active_record_encryption.rb.
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ── External delivery database (M4.5 Phase 2/3) ───────────────────────────────
# The customer/target database is configured per-tenant inside the app (the
# Destinations UI), with credentials encrypted at rest using the keys above —
# no connection details belong in this file.
