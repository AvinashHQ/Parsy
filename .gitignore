# macOS
.DS_Store

# Local environment
.env*
!.env.example

# IDEs
.idea/
.vscode/

# Rails secrets
/config/master.key
/config/credentials/*.key
/.kamal/secrets

# Bundler
/.bundle
/vendor/bundle

# Node/package managers
/node_modules

# Logs and temp files
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
!/tmp/pids
/tmp/pids/*
!/tmp/pids/.keep

# Active Storage local files
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage
!/tmp/storage/.keep

# Test/runtime artifacts
/coverage/
/public/assets
/public/packs
/public/packs-test
/app/assets/builds/*
!/app/assets/builds/.keep

# SQLite/db dumps if generated locally
*.sqlite3
*.sqlite3-*
*.dump
