{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avinashhq.local/schemas/region-profile-v1.json",
  "title": "Invoice Region Profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "status",
    "jurisdictions",
    "supported_languages",
    "capabilities",
    "currency_overrides",
    "validators"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "enum": [
        "disabled",
        "experimental",
        "pilot",
        "supported",
        "deprecated"
      ]
    },
    "jurisdictions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "supported_languages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "extraction",
        "identifier_validation",
        "tax_semantics",
        "structured_conformance",
        "export_adapters"
      ],
      "properties": {
        "extraction": {
          "enum": [
            "none",
            "experimental",
            "benchmarked"
          ]
        },
        "identifier_validation": {
          "enum": [
            "none",
            "partial",
            "benchmarked"
          ]
        },
        "tax_semantics": {
          "enum": [
            "none",
            "partial",
            "benchmarked"
          ]
        },
        "structured_conformance": {
          "enum": [
            "none",
            "partial",
            "benchmarked"
          ]
        },
        "export_adapters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "currency_overrides": {
      "type": "object"
    },
    "validators": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unsupported_scenarios": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
