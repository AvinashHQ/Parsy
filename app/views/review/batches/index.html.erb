<% content_for :title, "Batches · Parsy" %>
<% content_for :head do %>
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
<% end %>
<%= turbo_stream_from current_tenant if current_tenant %>

<%= page_header "Batches", subtitle: "Invoice processing batches for #{current_tenant&.name}." do %>
  <%= link_to new_review_upload_path, class: "btn btn-primary" do %>
    <%= icon "file-text", class: "size-4" %> Upload invoices
  <% end %>
<% end %>

<% if @batches.any? %>
  <div class="card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="border-b border-line bg-subtle text-xs">
          <tr>
            <th class="px-4 py-2.5 font-medium">Name</th>
            <th class="px-4 py-2.5 font-medium">Status</th>
            <th class="px-4 py-2.5 font-medium">Documents</th>
            <th class="px-4 py-2.5 font-medium">Updated</th>
            <th class="w-10 px-4 py-2.5"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line">
          <% @batches.each do |batch| %>
            <tr class="group relative transition-colors hover:bg-subtle">
              <td class="px-4 py-3">
                <%= link_to batch.name, review_batch_path(batch),
                      class: "font-medium text-ink no-underline after:absolute after:inset-0 hover:no-underline" %>
              </td>
              <td class="px-4 py-3"><%= status_badge batch.status %></td>
              <td class="px-4 py-3 text-muted"><%= batch.documents.count %></td>
              <td class="px-4 py-3 text-muted">
                <time datetime="<%= batch.updated_at.iso8601 %>" title="<%= batch.updated_at.strftime("%-d %b %Y, %H:%M") %>">
                  <%= time_ago_in_words(batch.updated_at) %> ago
                </time>
              </td>
              <td class="px-4 py-3 text-right">
                <%= icon "chevron-right", class: "ml-auto size-4 text-faint transition-transform group-hover:translate-x-0.5" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <%= empty_state "layers", "No batches yet", "Batches appear here once invoices are ingested into the pipeline." %>
  <div class="mt-4 flex justify-center">
    <%= link_to "Upload your first invoice", new_review_upload_path, class: "btn btn-primary mt-4" %>
  </div>
<% end %>
