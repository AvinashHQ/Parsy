<% content_for :title, "Document review · Parsy" %>

<% if @revision.nil? %>
  <% content_for :head do %>
    <meta name="turbo-refresh-method" content="morph">
  <% end %>
  <%= turbo_stream_from @document %>

  <% meta = @document.source_metadata || {} %>
  <% prov = @document.processing_provenance || {} %>
  <% extraction_error = prov.dig("extraction", "error_code") %>
  <% intake_reason = meta["rejection_code"] || prov.dig("intake", "rejection_code") %>
  <% reason_code = extraction_error || intake_reason %>
  <% in_progress = %w[uploaded inspecting routed_structured routed_visual extracting validating].include?(@document.status.to_s) %>
  <% state = case @document.status.to_s
       when "uploaded", "inspecting", "routed_structured", "routed_visual", "extracting", "validating"
         { tone: "info", icon: "loader", title: "Extraction in progress",
           body: "The extractor is reading this document. This page will update automatically when the extracted record, findings, and evidence are ready." }
       when "needs_review"
         { tone: "warning", icon: "clock", title: "Awaiting extraction",
           body: "This document is queued but has no candidate revision yet. Run extraction to populate the review record — this page will update automatically once a run starts." }
       when "failed"
         { tone: "danger", icon: "triangle-alert", title: "Extraction failed",
           body: "The extractor could not produce a candidate record for this document. You can retry extraction below." }
       when "quarantined"
         { tone: "danger", icon: "shield", title: "Quarantined during intake",
           body: "This document was held back during intake and was not extracted. Review the intake details below." }
       else
         { tone: "warning", icon: "triangle-alert", title: "No candidate revision available",
           body: "This document has no candidate revision and remains in #{@document.status.to_s.humanize.downcase}." }
     end %>
  <% tone_classes = {
       "info" => "border-info-line bg-info-subtle text-info-fg",
       "warning" => "border-warning-line bg-warning-subtle text-warning-fg",
       "danger" => "border-danger-line bg-danger-subtle text-danger-fg"
     } %>

  <%= page_header "Document review",
        breadcrumbs: [["Batches", review_batches_path], [@document.batch.name, review_batch_path(@document.batch)]] do %>
    <%= status_badge @document.status %>
    <%= risk_chip @document.risk_score %>
  <% end %>

  <%# Keep this phrase for accessibility + intake regression coverage %>
  <p class="sr-only">No candidate revision available</p>

  <section class="card border <%= tone_classes[state[:tone]] %> p-5" aria-label="Extraction status">
    <div class="flex items-start gap-3">
      <%= icon state[:icon], class: "mt-0.5 size-5 shrink-0 #{'animate-spin' if in_progress}" %>
      <div class="min-w-0 flex-1">
        <h2 class="text-sm font-semibold"><%= state[:title] %></h2>
        <p class="mt-1 text-sm opacity-90"><%= state[:body] %></p>
        <% if reason_code.present? %>
          <p class="mt-2 inline-flex items-center gap-1.5 rounded-md bg-surface/60 px-2 py-1 font-mono text-xs">
            <%= icon "info", class: "size-3.5" %> <%= reason_code %>
          </p>
        <% end %>
      </div>
      <% unless @document.status.to_s == "exported" %>
        <%= button_to extract_review_document_path(@document), method: :post,
              class: "btn btn-primary btn-sm shrink-0" do %>
          <%= icon "refresh", class: "size-4" %> <%= @document.status.to_s == "failed" ? "Retry extraction" : "Run extraction" %>
        <% end %>
      <% end %>
    </div>
  </section>

  <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(0,3fr)]">
    <%# ---------- Left: source preview ---------- %>
    <div class="space-y-5 lg:sticky lg:top-28 lg:self-start">
      <%= render "source_preview", document: @document, meta: meta %>
    </div>

    <%# ---------- Right: profile + intake + timeline ---------- %>
    <div class="space-y-5">
      <section class="card p-5" aria-label="Source and profile">
        <h2 class="mb-3 text-sm font-medium text-ink">Source &amp; profile</h2>
        <dl class="grid grid-cols-1 gap-x-4 gap-y-3 text-sm sm:grid-cols-2">
          <% profile_rows = {
               "Document" => @document.source_sha256.to_s.first(12),
               "Route" => @document.route,
               "Source format" => [@document.source_format_family, @document.source_format_profile, @document.source_format_version].compact.join(" / ").presence,
               "MIME type" => meta["mime_type"],
               "Pages" => meta["page_count"],
               "Size" => (number_to_human_size(meta["byte_size"].to_i) if meta["byte_size"].present?)
             } %>
          <% profile_rows.each do |label, value| %>
            <div>
              <dt class="text-xs text-muted"><%= label %></dt>
              <dd class="mt-0.5 font-mono text-xs text-ink"><%= value.presence || "—" %></dd>
            </div>
          <% end %>
        </dl>
      </section>

      <section class="card overflow-hidden" aria-label="Processing timeline">
        <div class="flex items-center gap-2 border-b border-line px-5 py-3">
          <h2 class="text-sm font-medium text-ink">Processing timeline</h2>
          <span class="rounded-full bg-subtle px-2 py-0.5 text-xs text-muted"><%= @events&.size.to_i %></span>
        </div>
        <% if @events&.any? %>
          <ul class="divide-y divide-line">
            <% @events.each do |event| %>
              <li class="flex items-start gap-3 px-5 py-3">
                <%= icon "circle-dot", class: "mt-0.5 size-3.5 shrink-0 text-faint" %>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5">
                    <span class="text-sm text-ink"><%= event.action.to_s.humanize %></span>
                    <span class="font-mono text-xs text-faint"><%= event.actor %></span>
                  </div>
                  <% if event.reason.present? %>
                    <p class="text-xs text-muted"><%= event.reason %></p>
                  <% end %>
                </div>
                <time class="shrink-0 text-xs text-faint" datetime="<%= event.created_at.iso8601 %>" title="<%= event.created_at.strftime("%-d %b %Y, %H:%M") %>">
                  <%= time_ago_in_words(event.created_at) %> ago
                </time>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="px-5 py-8 text-center text-sm text-muted">No processing events recorded yet.</p>
        <% end %>
      </section>

      <div>
        <%= link_to review_batch_path(@document.batch), class: "btn btn-secondary btn-sm" do %>
          <%= icon "arrow-left", class: "size-4" %> Back to batch
        <% end %>
      </div>
    </div>
  </div>
<% else %>
  <% meta = @document.source_metadata || {} %>
  <% sha = @document.source_sha256.to_s %>
  <% evidence_dom_id = ->(fp) { "evidence-#{fp.to_s.delete_prefix('/').parameterize}" } %>
  <% evidence_by_path = @revision.evidence_references.index_by(&:field_path) %>
  <% fid = ->(n) { n.tr("[", "_").delete("]") } %>
  <% findings = @revision.findings.order(Arel.sql("CASE severity WHEN 'CRITICAL' THEN 0 WHEN 'HIGH' THEN 1 WHEN 'MEDIUM' THEN 2 WHEN 'LOW' THEN 3 ELSE 4 END"), :code) %>
  <% refs = @revision.evidence_references.order(:field_path) %>
  <% locale = [@document.detected_language, @document.detected_country, @document.detected_currency].compact.join(" / ").presence %>

  <div data-controller="evidence">
    <nav class="mb-2 flex flex-wrap items-center gap-1.5 text-xs" aria-label="Breadcrumb">
      <%= link_to "Batches", review_batches_path, class: "text-muted no-underline hover:text-ink hover:no-underline" %>
      <%= icon "chevron-right", class: "size-3.5 text-faint" %>
      <%= link_to @document.batch.name, review_batch_path(@document.batch), class: "text-muted no-underline hover:text-ink hover:no-underline" %>
      <%= icon "chevron-right", class: "size-3.5 text-faint" %>
      <span class="font-mono text-ink"><%= sha.first(12) %></span>
    </nav>

    <div class="mb-4">
      <h1 class="text-xl font-medium tracking-tight text-ink">Document review</h1>
      <p class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-muted">
        <span class="font-mono text-xs"><%= sha.first(24) %>…</span>
        <% if @document.route.present? %><span class="text-faint">·</span><span><%= @document.route %></span><% end %>
        <% if locale %><span class="text-faint">·</span><span><%= locale %></span><% end %>
      </p>
    </div>

    <div class="sticky top-14 z-30 -mx-4 mb-6 border-y border-line bg-surface/85 px-4 py-2.5 backdrop-blur sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_badge @document.status %>
          <%= risk_chip @document.risk_score %>
          <% if @decision.auto_acceptable %>
            <span class="badge border-success-line bg-success-subtle text-success-fg"><%= icon "circle-check", class: "size-3.5" %> Ready for approval</span>
          <% else %>
            <span class="badge border-warning-line bg-warning-subtle text-warning-fg"><%= icon "triangle-alert", class: "size-3.5" %> <%= pluralize(@decision.reasons.size, "blocker") %></span>
          <% end %>
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <button type="submit" form="canonical-editor" accesskey="s" class="btn btn-secondary btn-sm">
            <%= icon "save", class: "size-4" %> Save <kbd class="kbd">S</kbd>
          </button>

          <%= button_to reject_review_document_path(@document),
                { method: :post, params: { reason: "operator rejection" },
                  form: { data: { turbo_confirm: "Reject this document? It will be sent back as rejected." } },
                  accesskey: "r", class: "btn btn-danger btn-sm" } do %>
            <%= icon "circle-x", class: "size-4" %> Reject <kbd class="kbd">R</kbd>
          <% end %>

          <% approve_opts = { method: :post,
               params: { confirm_blocking_findings: "true", reason: "operator explicit approval" },
               accesskey: "a", class: "btn btn-primary btn-sm" } %>
          <% approve_opts[:form] = { data: { turbo_confirm: "This document has unresolved blockers. Approve with override?" } } unless @decision.auto_acceptable %>
          <%= button_to approve_review_document_path(@document), approve_opts do %>
            <%= icon "circle-check", class: "size-4" %> <%= @decision.auto_acceptable ? "Approve" : "Override & approve" %> <kbd class="kbd">A</kbd>
          <% end %>

          <% if @next_document %>
            <%= link_to review_document_path(@next_document), accesskey: "n", class: "btn btn-ghost btn-sm" do %>
              Next <kbd class="kbd">N</kbd> <%= icon "arrow-right", class: "size-4" %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(0,3fr)]">
      <%# ---------- Left: source preview + profile ---------- %>
      <div class="space-y-5 lg:sticky lg:top-28 lg:self-start">
        <%= render "source_preview", document: @document, meta: meta %>

        <section class="card p-5" aria-label="Source and profile">
          <h2 class="mb-3 text-sm font-medium text-ink">Source &amp; profile</h2>
          <dl class="grid grid-cols-1 gap-x-4 gap-y-3 text-sm sm:grid-cols-2">
            <% profile_rows = {
                 "Route" => @document.route,
                 "Source format" => [@document.source_format_family, @document.source_format_profile, @document.source_format_version].compact.join(" / ").presence,
                 "Language" => @document.detected_language,
                 "Country" => @document.detected_country,
                 "Currency" => @document.detected_currency,
                 "Rule pack" => [@document.rule_pack_id, @document.rule_pack_version].compact.join(" ").presence,
                 "Capability" => (@document.capability_profile || @revision.provenance.to_h.dig("capability", "level"))
               } %>
            <% profile_rows.each do |label, value| %>
              <div>
                <dt class="text-xs text-muted"><%= label %></dt>
                <dd class="mt-0.5 font-mono text-xs text-ink"><%= value.presence || "—" %></dd>
              </div>
            <% end %>
          </dl>
        </section>
      </div>

      <%# ---------- Right: acceptance, findings, editor, evidence ---------- %>
      <div class="space-y-5">
        <section class="card p-5" aria-label="Acceptance policy">
          <h2 class="mb-3 text-sm font-medium text-ink">Acceptance policy</h2>
          <% if @decision.auto_acceptable %>
            <div class="flex items-center gap-2 rounded-lg border border-success-line bg-success-subtle px-3 py-2.5 text-sm text-success-fg">
              <%= icon "circle-check", class: "size-4 shrink-0" %>
              Ready for approval — no blocking conditions.
            </div>
          <% else %>
            <p class="mb-3 text-sm text-muted">Operator confirmation is required before approval:</p>
            <ul class="space-y-2">
              <% @decision.reasons.each do |reason| %>
                <li class="flex gap-2 text-sm text-ink">
                  <%= icon "circle-alert", class: "mt-0.5 size-4 shrink-0 text-warning" %>
                  <span><%= reason %></span>
                </li>
              <% end %>
            </ul>
          <% end %>
        </section>

        <section class="card overflow-hidden" aria-label="Validation findings">
          <div class="flex items-center justify-between gap-2 border-b border-line px-5 py-3">
            <h2 class="text-sm font-medium text-ink">Risk-sorted findings</h2>
            <span class="rounded-full bg-subtle px-2 py-0.5 text-xs text-muted"><%= findings.size %></span>
          </div>
          <% if findings.any? %>
            <ul class="divide-y divide-line">
              <% findings.each do |finding| %>
                <li class="px-5 py-3.5">
                  <div class="flex flex-wrap items-center gap-2">
                    <%= severity_badge finding.severity %>
                    <span class="font-mono text-xs text-muted"><%= finding.code %></span>
                    <% if finding.resolution_state.present? && finding.resolution_state != "unresolved" %>
                      <span class="text-xs text-faint">· <%= finding.resolution_state.humanize.downcase %></span>
                    <% end %>
                  </div>
                  <p class="mt-2 text-sm text-ink"><%= finding.message %></p>
                  <% if finding.observed.present? || finding.calculated.present? %>
                    <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-muted">
                      <% if finding.observed.present? %><span>observed <span class="font-mono text-ink"><%= finding.observed %></span></span><% end %>
                      <% if finding.calculated.present? %><span>expected <span class="font-mono text-ink"><%= finding.calculated %></span></span><% end %>
                    </div>
                  <% end %>
                  <% if finding.field_paths.present? %>
                    <div class="mt-2.5 flex flex-wrap gap-1.5">
                      <% finding.field_paths.each do |fp| %>
                        <a href="#<%= evidence_dom_id.call(fp) %>"
                           data-action="evidence#highlight" data-evidence-id-param="<%= evidence_dom_id.call(fp) %>"
                           class="inline-flex items-center gap-1 rounded-md bg-subtle px-1.5 py-0.5 font-mono text-xs text-accent no-underline hover:underline">
                          <%= icon "git-branch", class: "size-3" %><%= fp %>
                        </a>
                      <% end %>
                    </div>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="px-5 py-8 text-center text-sm text-muted">No validation findings on this revision.</p>
          <% end %>
        </section>

        <% ci         = @revision.canonical_invoice.to_h %>
        <% inv        = (ci["invoice"] || {}) %>
        <% supplier   = (ci["supplier"] || {}) %>
        <% buyer      = (ci["buyer"] || {}) %>
        <% payee      = ci["payee"].presence %>
        <% line_items = Array(ci["line_items"]) %>
        <% totals     = (ci["totals"] || {}) %>
        <% tax_rows   = Array(ci["tax_breakdowns"]) %>
        <% refs_list  = Array(ci["references"]) %>
        <% currency   = inv["currency"].to_s %>
        <% nz         = ->(v) { v.present? && v.to_f.abs > 0 } %>
        <% money      = ->(v) { v.present? ? [v, currency.presence].compact.join(" ") : "—" } %>
        <% addr_line  = ->(a) { a ||= {}; [Array(a["lines"]).join(", "), a["city"], a["postal_code"], a["country_code"]].reject(&:blank?).join(", ") } %>
        <section class="card overflow-hidden" aria-label="Extracted record">
          <div class="flex items-center justify-between gap-2 border-b border-line px-5 py-3">
            <h2 class="text-sm font-medium text-ink">Extracted record</h2>
            <span class="hidden text-xs text-muted sm:inline">Read-only · verify against the source</span>
          </div>

          <%# Parties %>
          <div class="grid gap-px bg-line sm:grid-cols-2">
            <% parties = [["Supplier", supplier], ["Buyer", buyer]] %>
            <% parties << ["Payee", payee] if payee %>
            <% parties.each do |role, p| %>
              <div class="bg-surface p-5">
                <p class="text-xs font-medium uppercase tracking-wide text-muted"><%= role %></p>
                <p class="mt-1.5 text-sm font-medium text-ink"><%= p["display_name"].presence || "—" %></p>
                <% if p["legal_name"].present? && p["legal_name"] != p["display_name"] %>
                  <p class="text-xs text-muted"><%= p["legal_name"] %></p>
                <% end %>
                <% if addr_line.call(p["address"]).present? %>
                  <p class="mt-1.5 text-xs text-muted"><%= addr_line.call(p["address"]) %></p>
                <% end %>
                <% Array(p["identifiers"]).each do |id| %>
                  <p class="mt-1 font-mono text-xs text-muted"><%= id["scheme"] %> · <span class="text-ink"><%= id["value"] %></span></p>
                <% end %>
              </div>
            <% end %>
          </div>

          <%# Invoice details %>
          <div class="border-t border-line p-5">
            <dl class="grid grid-cols-2 gap-x-4 gap-y-3 sm:grid-cols-4">
              <% [["Number", inv["number"]], ["Currency", inv["currency"]],
                  ["Issue date", inv["issue_date"]], ["Due date", inv["due_date"]],
                  ["Tax point", inv["tax_point_date"]], ["Tax currency", inv["tax_currency"]]].each do |label, value| %>
                <div>
                  <dt class="text-xs text-muted"><%= label %></dt>
                  <dd class="mt-0.5 font-mono text-xs text-ink"><%= value.presence || "—" %></dd>
                </div>
              <% end %>
              <% if inv["payment_terms_text"].present? %>
                <div class="col-span-2 sm:col-span-4">
                  <dt class="text-xs text-muted">Payment terms</dt>
                  <dd class="mt-0.5 text-xs text-ink"><%= inv["payment_terms_text"] %></dd>
                </div>
              <% end %>
              <% if refs_list.any? %>
                <div class="col-span-2 sm:col-span-4">
                  <dt class="text-xs text-muted">References</dt>
                  <dd class="mt-1 flex flex-wrap gap-1.5">
                    <% refs_list.each do |r| %>
                      <span class="inline-flex items-center gap-1 rounded-md bg-subtle px-1.5 py-0.5 font-mono text-xs text-muted">
                        <%= r["type"].to_s.tr("_", " ") %> · <span class="text-ink"><%= r["value"] %></span>
                      </span>
                    <% end %>
                  </dd>
                </div>
              <% end %>
            </dl>
          </div>

          <%# Line items %>
          <% if line_items.any? %>
            <div class="overflow-x-auto border-t border-line">
              <table class="w-full text-sm">
                <thead class="border-b border-line bg-subtle text-xs text-muted">
                  <tr>
                    <th class="px-5 py-2 text-left font-medium">#</th>
                    <th class="px-3 py-2 text-left font-medium">Description</th>
                    <th class="px-3 py-2 text-right font-medium">Qty</th>
                    <th class="px-3 py-2 text-right font-medium">Unit price</th>
                    <th class="px-3 py-2 text-right font-medium">Tax</th>
                    <th class="px-5 py-2 text-right font-medium">Net</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-line">
                  <% line_items.each do |li| %>
                    <% li_tax = Array(li["tax_breakdowns"]).first || {} %>
                    <tr>
                      <td class="px-5 py-2.5 align-top text-muted"><%= li["line_no"] || "—" %></td>
                      <td class="px-3 py-2.5 align-top text-ink"><%= li["description"].presence || li["item_name"].presence || "—" %></td>
                      <td class="whitespace-nowrap px-3 py-2.5 text-right align-top font-mono text-xs text-ink"><%= [li["quantity"], li["unit_code"]].compact.join(" ") %></td>
                      <td class="px-3 py-2.5 text-right align-top font-mono text-xs text-ink"><%= li["unit_price"].presence || "—" %></td>
                      <td class="px-3 py-2.5 text-right align-top font-mono text-xs text-muted"><%= li_tax["rate"].present? ? "#{li_tax["rate"]}%" : "—" %></td>
                      <td class="px-5 py-2.5 text-right align-top font-mono text-xs text-ink"><%= li["line_net_amount"].presence || "—" %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>

          <%# Totals %>
          <div class="border-t border-line p-5">
            <div class="ml-auto max-w-xs space-y-1.5 text-sm">
              <% [["Line extension", totals["line_extension_amount"], :auto],
                  ["Allowances", totals["allowance_total_amount"], :nz],
                  ["Charges", totals["charge_total_amount"], :nz],
                  ["Tax exclusive", totals["tax_exclusive_amount"], :always],
                  ["Total tax", totals["total_tax_amount"], :always],
                  ["Tax inclusive", totals["tax_inclusive_amount"], :always],
                  ["Prepaid", totals["prepaid_amount"], :nz],
                  ["Withholding", totals["withholding_total_amount"], :nz],
                  ["Rounding", totals["rounding_amount"], :nz]].each do |label, value, mode| %>
                <% next if mode == :nz && !nz.call(value) %>
                <% next if mode == :auto && value.blank? %>
                <div class="flex items-center justify-between gap-4">
                  <span class="text-muted"><%= label %></span>
                  <span class="font-mono text-xs text-ink"><%= money.call(value) %></span>
                </div>
              <% end %>
              <div class="mt-2 flex items-center justify-between gap-4 border-t border-line pt-2.5">
                <span class="font-medium text-ink">Payable</span>
                <span class="font-mono text-sm font-medium text-ink"><%= money.call(totals["payable_amount"]) %></span>
              </div>
            </div>
          </div>

          <%# Tax breakdown %>
          <% if tax_rows.any? %>
            <div class="border-t border-line px-5 py-4">
              <p class="mb-2.5 text-xs font-medium uppercase tracking-wide text-muted">Tax breakdown</p>
              <div class="overflow-x-auto">
                <table class="w-full text-xs">
                  <thead class="text-muted">
                    <tr>
                      <th class="py-1 text-left font-medium">Type</th>
                      <th class="py-1 text-left font-medium">Category</th>
                      <th class="py-1 text-right font-medium">Rate</th>
                      <th class="py-1 text-right font-medium">Taxable</th>
                      <th class="py-1 text-right font-medium">Tax</th>
                    </tr>
                  </thead>
                  <tbody class="font-mono text-ink">
                    <% tax_rows.each do |t| %>
                      <tr class="border-t border-line">
                        <td class="py-1.5 pr-2"><%= t["tax_type"] %><%= " · RC" if t["reverse_charge"] %></td>
                        <td class="py-1.5 pr-2 text-muted"><%= t["category_code"].presence || "—" %></td>
                        <td class="py-1.5 text-right"><%= t["rate"].present? ? "#{t["rate"]}%" : "—" %></td>
                        <td class="py-1.5 text-right"><%= t["taxable_amount"].presence || "—" %></td>
                        <td class="py-1.5 text-right"><%= t["tax_amount"].presence || "—" %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          <% end %>
        </section>

        <section class="card p-5" aria-label="Canonical editor">
          <h2 class="text-sm font-medium text-ink">Correct high-risk fields</h2>
          <p class="mt-1 text-sm text-muted">Only these high-risk fields are editable. Saving creates a new revision.</p>

          <%= form_with url: review_document_path(@document), method: :patch, id: "canonical-editor", class: "mt-4" do |form| %>
            <div class="space-y-4">
              <% high_risk = [
                   ["/supplier/display_name", "Supplier display name", "canonical_invoice[supplier][display_name]", @revision.canonical_invoice.to_h.dig("supplier", "display_name")],
                   ["/invoice/number", "Invoice number", "canonical_invoice[invoice][number]", @revision.canonical_invoice.to_h.dig("invoice", "number")],
                   ["/invoice/currency", "Currency", "canonical_invoice[invoice][currency]", @revision.canonical_invoice.to_h.dig("invoice", "currency")],
                   ["/totals/payable_amount", "Payable amount", "canonical_invoice[totals][payable_amount]", @revision.canonical_invoice.to_h.dig("totals", "payable_amount")]
                 ] %>
              <% high_risk.each do |path, label, name, value| %>
                <% changed = @revision.changed_field_paths.to_a.include?(path) %>
                <% ev = evidence_by_path[path] %>
                <div>
                  <div class="mb-1.5 flex items-center gap-2">
                    <%= label_tag fid.call(name), label, class: "text-sm font-medium text-ink" %>
                    <% if changed %>
                      <span class="badge border-info-line bg-info-subtle text-info-fg"><%= icon "pencil", class: "size-3" %> Edited</span>
                    <% end %>
                  </div>
                  <%= text_field_tag name, value, id: fid.call(name), class: "font-mono",
                        aria: { describedby: evidence_dom_id.call(path) },
                        data: { action: "focus->evidence#highlight", evidence_id_param: evidence_dom_id.call(path) } %>
                  <% if ev %>
                    <button type="button" data-action="evidence#highlight" data-evidence-id-param="<%= evidence_dom_id.call(path) %>"
                            class="mt-1.5 inline-flex items-center gap-1.5 text-xs text-muted hover:text-accent">
                      <%= icon "eye", class: "size-3.5" %>
                      Evidence: <%= ev.source_kind %><%= " · p.#{ev.page}" if ev.page %>
                    </button>
                  <% end %>
                </div>
              <% end %>
            </div>

            <details class="group mt-5 border-t border-line pt-4">
              <summary class="flex cursor-pointer list-none items-center justify-between text-sm font-medium text-ink [&::-webkit-details-marker]:hidden">
                <span class="flex items-center gap-2"><%= icon "git-branch", class: "size-4 text-faint" %> Locale, format &amp; rule pack overrides</span>
                <%= icon "chevron-down", class: "size-4 text-faint transition-transform group-open:rotate-180" %>
              </summary>
              <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
                <% overrides = [
                     ["overrides[document_language]", "Language", @document.detected_language],
                     ["overrides[supplier_country]", "Country", @document.detected_country],
                     ["overrides[currency]", "Currency", @document.detected_currency],
                     ["overrides[source_format_family]", "Format", @document.source_format_family],
                     ["overrides[rule_pack_id]", "Rule pack", @document.rule_pack_id],
                     ["overrides[rule_pack_version]", "Rule pack version", @document.rule_pack_version]
                   ] %>
                <% overrides.each do |name, label, value| %>
                  <div>
                    <%= label_tag fid.call(name), label, class: "mb-1.5 block text-sm text-muted" %>
                    <%= text_field_tag name, value, id: fid.call(name), class: "font-mono" %>
                  </div>
                <% end %>
              </div>
            </details>

            <div class="mt-5 border-t border-line pt-4">
              <%= label_tag :reason, "Reason for changes", class: "mb-1.5 block text-sm text-muted" %>
              <%= text_field_tag :reason, nil, placeholder: "e.g. corrected supplier name from page 1 header" %>
              <div class="mt-3 flex justify-end">
                <%= form.submit "Save revision", class: "btn btn-secondary" %>
              </div>
            </div>
          <% end %>
        </section>

        <section class="card overflow-hidden" aria-label="Evidence references">
          <div class="flex items-center justify-between gap-2 border-b border-line px-5 py-3">
            <h2 class="text-sm font-medium text-ink">Evidence</h2>
            <span class="rounded-full bg-subtle px-2 py-0.5 text-xs text-muted"><%= refs.size %></span>
          </div>
          <% if refs.any? %>
            <ul class="divide-y divide-line">
              <% refs.each do |ev| %>
                <li id="<%= evidence_dom_id.call(ev.field_path) %>" tabindex="-1" class="scroll-mt-28 px-5 py-3 transition duration-500">
                  <div class="flex flex-wrap items-center justify-between gap-2">
                    <span class="font-mono text-xs text-accent"><%= ev.field_path %></span>
                    <div class="flex items-center gap-2.5 text-xs text-muted">
                      <span class="inline-flex items-center gap-1">
                        <%= icon(ev.source_kind.to_s == "operator_confirmation" ? "user" : "file-text", class: "size-3.5") %>
                        <%= ev.source_kind %>
                      </span>
                      <% if ev.page %><span>p.<%= ev.page %></span><% end %>
                      <% if ev.operator_confirmed? %>
                        <span class="inline-flex items-center gap-1 text-success-fg"><%= icon "circle-check", class: "size-3.5" %> confirmed</span>
                      <% end %>
                    </div>
                  </div>
                  <% if ev.text_snippet.present? %>
                    <p class="mt-1.5 rounded-md bg-subtle px-2.5 py-1.5 font-mono text-xs text-muted">“<%= ev.text_snippet %>”</p>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="px-5 py-8 text-center text-sm text-muted">No evidence references recorded for this revision.</p>
          <% end %>
        </section>
      </div>
    </div>
  </div>
<% end %>
